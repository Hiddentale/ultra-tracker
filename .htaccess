Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://unpkg.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://unpkg.com https://fonts.googleapis.com; img-src 'self' data: https://*.tile.openstreetmap.org; connect-src 'self' https://ultra-tracker.expeditionorion.workers.dev; font-src 'self' https://fonts.gstatic.com; frame-src 'none'; object-src 'none'"
